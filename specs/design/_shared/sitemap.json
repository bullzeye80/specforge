{
  "version": "2",
  "nodes": [
    {
      "id": "page:landing",
      "label": "Landing",
      "depth": 0,
      "kind": "primary",
      "url": "/",
      "purpose": "Search-stage marketing: reframe the problem ('coding agents flail on vague prompts') to 'produce a disciplined spec, not another screen'. App-shaped freemium hero, no demo gate.",
      "auth": "none",
      "context": "context:shaping",
      "objects": [],
      "screens": ["screen:landing/main"],
      "appears-in-flows": ["flow:acquisition"]
    },
    {
      "id": "page:pricing",
      "label": "Pricing",
      "depth": 0,
      "kind": "secondary",
      "url": "/pricing",
      "purpose": "Freemium pricing: Free + Pro, differentiated on the artifact meter (the value metric tied to KUI). No hidden price, no card to start free.",
      "auth": "none",
      "context": "context:billing",
      "objects": [],
      "screens": ["screen:pricing/main"],
      "appears-in-flows": ["flow:acquisition"]
    },
    {
      "id": "page:sign-up",
      "label": "Sign up",
      "depth": 0,
      "kind": "primary",
      "url": "/signup",
      "purpose": "Select-stage sign-up: email / magic-link only, no card, no company/role/use-case fields. Lightest sign-up that still reaches First Strike.",
      "auth": "none",
      "context": "context:identity",
      "objects": ["object:identity.user"],
      "screens": ["screen:auth/sign-up"],
      "appears-in-flows": ["flow:onboarding"]
    },
    {
      "id": "page:sign-in",
      "label": "Sign in",
      "depth": 0,
      "kind": "utility",
      "url": "/signin",
      "purpose": "Returning-user authentication (email / magic-link). Opens a session and returns to the dashboard.",
      "auth": "none",
      "context": "context:identity",
      "objects": ["object:identity.user"],
      "screens": ["screen:auth/sign-in"],
      "appears-in-flows": ["flow:daily-use"]
    },
    {
      "id": "page:onboarding",
      "label": "Describe your idea",
      "depth": 0,
      "kind": "primary",
      "url": "/start",
      "purpose": "Setup-stage: the single on-line step. Capture the fuzzy idea (typed or pasted) and create the product from it. Profile / workspace / plan are deferred off the Straight-Line.",
      "auth": "required",
      "context": "context:shaping",
      "objects": ["object:shaping.idea-seed", "object:shaping.product"],
      "screens": ["screen:onboarding/describe-idea"],
      "appears-in-flows": ["flow:onboarding"]
    },
    {
      "id": "page:shape",
      "label": "Anchor result",
      "depth": 1,
      "kind": "primary",
      "url": "/p/:productId/shape",
      "purpose": "Showcase-stage First Strike surface: the skeleton product.md comes back from the fuzzy idea and is viewable. Where event:shaping.artifact-generated fires for the first time.",
      "auth": "required",
      "context": "context:shaping",
      "objects": ["object:shaping.product", "object:shaping.artifact", "object:shaping.idea-seed"],
      "screens": ["screen:shape/anchor-result"],
      "appears-in-flows": ["flow:onboarding", "flow:shaping"]
    },
    {
      "id": "page:dashboard",
      "label": "Dashboard",
      "depth": 0,
      "kind": "primary",
      "url": "/home",
      "purpose": "Daily entry point after auth: lists the founder's products and their depth/status, and makes the growing artifact tree visible (the retention surface). Entry to shaping and to starting a new product.",
      "auth": "required",
      "context": "context:shaping",
      "objects": ["object:shaping.product"],
      "screens": ["screen:dashboard/main"],
      "appears-in-flows": ["flow:daily-use", "flow:onboarding"]
    },
    {
      "id": "page:product",
      "label": "Product workspace",
      "depth": 1,
      "kind": "primary",
      "url": "/p/:productId",
      "purpose": "Showcase-stage: one product's artifact tree — the anchor and every downstream artifact and feature. The surface where PAI/KUI repeat (generating and refining artifacts).",
      "auth": "required",
      "context": "context:shaping",
      "objects": ["object:shaping.product", "object:shaping.artifact", "object:shaping.feature"],
      "screens": ["screen:product/tree"],
      "appears-in-flows": ["flow:shaping", "flow:daily-use"]
    },
    {
      "id": "page:product.artifact",
      "label": "Artifact",
      "depth": 2,
      "kind": "deep",
      "url": "/p/:productId/a/:artifactId",
      "purpose": "View, refine, edit (inline, document-style), or export a single spec artifact — the unit of value specforge produces.",
      "auth": "required",
      "context": "context:shaping",
      "objects": ["object:shaping.artifact"],
      "screens": ["screen:artifact/view"],
      "appears-in-flows": ["flow:shaping"]
    },
    {
      "id": "page:product.feature",
      "label": "Feature",
      "depth": 2,
      "kind": "deep",
      "url": "/p/:productId/f/:featureSlug",
      "purpose": "A feature within a product: its shape.md and downstream feature-scope artifacts, tied to a journey target-stage and milestone.",
      "auth": "required",
      "context": "context:shaping",
      "objects": ["object:shaping.feature", "object:shaping.artifact"],
      "screens": ["screen:feature/detail"],
      "appears-in-flows": ["flow:shaping"]
    },
    {
      "id": "page:settings",
      "label": "Settings",
      "depth": 1,
      "kind": "utility",
      "url": "/settings",
      "purpose": "Account settings: profile (modal-edited discrete entity) and a symmetric-escape delete-account path.",
      "auth": "required",
      "context": "context:identity",
      "objects": ["object:identity.user"],
      "screens": ["screen:settings/profile"],
      "appears-in-flows": ["flow:account"]
    },
    {
      "id": "page:settings.billing",
      "label": "Plan & usage",
      "depth": 2,
      "kind": "utility",
      "url": "/settings/billing",
      "purpose": "Scale-stage: view plan and the artifact meter, upgrade at the moment the free meter is reached, and downgrade/cancel one click (symmetric to sign-up). Hosts the freemium paywall surface.",
      "auth": "required",
      "context": "context:billing",
      "objects": ["object:billing.subscription", "object:billing.artifact-quota"],
      "screens": ["screen:billing/plan", "screen:billing/paywall"],
      "appears-in-flows": ["flow:upgrade"]
    }
  ],
  "edges": [
    { "from": "page:landing", "to": "page:sign-up", "kind": "navigation", "trigger": "hero-cta", "primary": true },
    { "from": "page:landing", "to": "page:sign-in", "kind": "navigation", "trigger": "nav-sign-in", "primary": false },
    { "from": "page:landing", "to": "page:pricing", "kind": "navigation", "trigger": "nav-pricing", "primary": false },
    { "from": "page:landing", "to": "page:dashboard", "kind": "conditional", "trigger": "authenticated-visit", "primary": false },
    { "from": "page:pricing", "to": "page:sign-up", "kind": "navigation", "trigger": "plan-cta", "primary": true },
    { "from": "page:sign-up", "to": "page:onboarding", "kind": "redirect", "trigger": "sign-up-success", "primary": true },
    { "from": "page:sign-in", "to": "page:dashboard", "kind": "redirect", "trigger": "sign-in-success", "primary": true },
    { "from": "page:onboarding", "to": "page:shape", "kind": "redirect", "trigger": "idea-submitted", "primary": true },
    { "from": "page:shape", "to": "page:product", "kind": "navigation", "trigger": "view-full-tree", "primary": true },
    { "from": "page:shape", "to": "page:dashboard", "kind": "navigation", "trigger": "go-home", "primary": false },
    { "from": "page:shape", "to": "page:settings.billing", "kind": "inline-flow", "trigger": "quota-reached", "primary": false },
    { "from": "page:dashboard", "to": "page:product", "kind": "navigation", "trigger": "product-card", "primary": true },
    { "from": "page:dashboard", "to": "page:onboarding", "kind": "navigation", "trigger": "new-product", "primary": false },
    { "from": "page:dashboard", "to": "page:settings", "kind": "navigation", "trigger": "user-menu", "primary": false },
    { "from": "page:dashboard", "to": "page:settings.billing", "kind": "navigation", "trigger": "user-menu", "primary": false },
    { "from": "page:product", "to": "page:product.artifact", "kind": "navigation", "trigger": "tree-node", "primary": true },
    { "from": "page:product", "to": "page:product.feature", "kind": "navigation", "trigger": "feature-node", "primary": false },
    { "from": "page:product", "to": "page:settings.billing", "kind": "inline-flow", "trigger": "quota-reached", "primary": false },
    { "from": "page:product.feature", "to": "page:product.artifact", "kind": "navigation", "trigger": "feature-artifact", "primary": false },
    { "from": "page:settings", "to": "page:settings.billing", "kind": "navigation", "trigger": "settings-nav", "primary": false }
  ]
}
